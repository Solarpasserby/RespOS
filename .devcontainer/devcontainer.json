{
  "name": "OS Contest",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "overrideCommand": true,
  "workspaceFolder": "/workspaces/RespOS",
  "remoteUser": "ubuntu",
  "shutdownAction": "stopContainer",
  "mounts": [
    "source=/home/lorenash/Code/kernel/RespOS/img/mnt,target=/workspaces/RespOS/img/mnt,type=bind"
  ],
  "forwardPorts": [
    1234
  ],
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined"
  ],
  "containerEnv": {
    "TERM": "xterm-256color"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "rust-analyzer.cargo.allTargets": false
      },
      "extensions": [
        "openai.chatgpt",
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "ms-vscode.makefile-tools"
      ]
    }
  }
}
