{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Kernel: CodeLLDB attach (debug)",
      "type": "lldb",
      "request": "launch",
      // Pre-launch task builds the kernel if needed, then starts QEMU with its GDB stub on port 1234.
      "targetCreateCommands": [
        "target create ${workspaceFolder}/os/target/riscv64gc-unknown-none-elf/debug/os"
      ],
      "processCreateCommands": [
        "gdb-remote 127.0.0.1:1234"
      ],
      "initCommands": [
        "settings set target.default-arch riscv64"
      ],
      "sourceLanguages": [
        "rust"
      ],
      "cwd": "${workspaceFolder}/os",
      "preLaunchTask": "os: qemu gdbserver (debug)"
    },
    {
      "name": "Kernel: CodeLLDB attach (release-debug)",
      "type": "lldb",
      "request": "launch",
      // Pre-launch task builds the kernel if needed, then starts QEMU with its GDB stub on port 1234.
      "targetCreateCommands": [
        "target create ${workspaceFolder}/os/target/riscv64gc-unknown-none-elf/release-debug/os"
      ],
      "processCreateCommands": [
        "gdb-remote 127.0.0.1:1234"
      ],
      "initCommands": [
        "settings set target.default-arch riscv64"
      ],
      "sourceLanguages": [
        "rust"
      ],
      "cwd": "${workspaceFolder}/os",
      "preLaunchTask": "os: qemu gdbserver (release-debug)"
    }
  ]
}
